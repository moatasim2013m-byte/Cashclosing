/** 2) SAVE TO SHEET (UPSERT + STRICT LOGIC) */
app.post("/api/save", async (req, res) => {
  try {
    console.log("Starting Save Process...");

    if (!SHEET_ID) {
      return res.status(500).json({ error: "Missing SPREADSHEET_ID" });
    }

   

    const data = req.body || {};

    // Inputs
    const opening = toNumber(data.opening_cash);
    const zOut = toNumber(data.z_out_total);
    const visa = toNumber(data.visa);
    const cliq = toNumber(data.transfer_cliq);
    const expenses = toNumber(data.expenses_total);
    const counted = toNumber(data.counted);
    const ownerWithdrawal = toNumber(data.owner_withdrawal);

    // Extras
    const toys = toNumber(data.toys_extra);
    const events = toNumber(data.birthdays) + toNumber(data.subscriptions);
    const other = toNumber(data.other_extra);

    // Strict business logic
    const totalSales = zOut + toys + events + other;
    const expectedCashBeforeExpenses = totalSales - visa - cliq;
    const expectedClosing =
      opening + expectedCashBeforeExpenses - expenses - ownerWithdrawal;
    const diff = counted - expectedClosing;

// Google Auth (ADC – Cloud Run service account)
const auth = new google.auth.GoogleAuth({
  scopes: ["https://www.googleapis.com/auth/spreadsheets"],
});

const sheets = google.sheets({ version: "v4", auth });











    // Verify sheet access
    try {
      await sheets.spreadsheets.values.get({
        spreadsheetId: SHEET_ID,
        range: `${SHEET_NAME}!A1`
      });
    } catch (e) {
      console.error("Sheet access error:", e?.message || e);
      return res.status(500).json({
        error: `Google Sheet Access Failed. Check tab name '${SHEET_NAME}' and sharing permissions.`
      });
    }

    // Row values (A-P)
    const dateObj = new Date(data.date);
    const days = ["Sunday","Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"];

    const rowValues = [
      data.shift, // A
      data.date, // B
      days[dateObj.getDay()] || "Unknown", // C
      opening, // D
      zOut, // E
      toys, // F
      events, // G
      other, // H
      toNumber(data.unpaid_debt), // I
      totalSales, // J
      expenses, // K
      visa, // L
      expectedCashBeforeExpenses, // M
      expectedClosing, // N
      counted, // O
      diff // P
    ];

    // Upsert by date in column B
    const getRows = await sheets.spreadsheets.values.get({
      spreadsheetId: SHEET_ID,
      range: `${SHEET_NAME}!B:B`
    });

    const existingDates = getRows.data.values ? getRows.data.values.flat() : [];
    const rowIndex = existingDates.findIndex((d) => d === data.date);

    if (rowIndex !== -1) {
      await sheets.spreadsheets.values.update({
        spreadsheetId: SHEET_ID,
        range: `${SHEET_NAME}!A${rowIndex + 1}:P${rowIndex + 1}`,
        valueInputOption: "USER_ENTERED",
        requestBody: { values: [rowValues] }
      });
      console.log(`Updated row for ${data.date}`);
    } else {
      await sheets.spreadsheets.values.append({
        spreadsheetId: SHEET_ID,
        range: `${SHEET_NAME}!A:P`,
        valueInputOption: "USER_ENTERED",
        requestBody: { values: [rowValues] }
      });
      console.log(`Appended row for ${data.date}`);
    }

    return res.json({ success: true });
  } catch (error) {
    console.error("FATAL SAVE ERROR:", error);
    return res.status(500).json({ error: error?.message || "Save failed" });
  }
});

/** React router fallback */
app.get("*", (req, res) => {
  res.sendFile(path.join(__dirname, "dist", "index.html"));
});

/** Start server */
const PORT = Number(process.env.PORT) || 8080;
app.listen(PORT, "0.0.0.0", () => {
  console.log(`✅ Server running on port ${PORT}`);
});
  console.log(`✅ Server running on port ${PORT}`);
});
